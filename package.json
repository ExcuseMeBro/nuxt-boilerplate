{
  "name": "nuxt-boilerplate",
  "private": true,
  "type": "module",
  "author": {
    "name": "Og'abek Shomurotov",
    "email": "bratsultan007@mail.ru",
    "url": "https://github.com/ExcuseMeBro"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxi typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test -- --run",
    "devtools:enable": "nuxi devtools enable",
    "devtools:disable": "nuxi devtools disable",
    "remotion:preview": "remotion preview remotion/index.ts",
    "remotion:render": "remotion render remotion/index.ts Intro public/intro.mp4",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.3.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "jwt-decode": "^4.0.0",
    "nuxt": "^4.4.4",
    "pinia": "^3.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@nuxt/test-utils": "^4.0.3",
    "@remotion/cli": "^4.0.456",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "^4.0.456",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,json,jsonc,css,md}": "biome check --write --no-errors-on-unmatched"
  },
  "packageManager": "npm@11.6.2"
}
